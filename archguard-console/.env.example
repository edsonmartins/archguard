# ArchGuard Console — Environment Variables
#
# Copy to .env (which is gitignored) and fill in the values below.
# Never commit a populated .env to the repo.

# ── Kanidm (ArchGuard ID) ────────────────────────────────────────────────
# Server URL used by the server runtime to reach Kanidm.
ARCHGUARD_ID_URL=https://auth.localhost:8443

# URL exposed to the browser for the OIDC redirect flow.
# In a typical deploy, equals ARCHGUARD_ID_URL.
VITE_ARCHGUARD_ID_URL=https://auth.localhost:8443

# Kanidm service account API token (read-write scope).
# Generate via:
#   kanidm service-account api-token generate -D admin \
#     --label console-token archguard-console-sa
# Rotate periodically; revoke leaked tokens with `api-token destroy`.
ARCHGUARD_SA_TOKEN=your-sa-token-here

# ── AliasVault ───────────────────────────────────────────────────────────
ARCHGUARD_VAULT_URL=https://vault.localhost

# ── Session encryption ───────────────────────────────────────────────────
# 32-byte hex string (64 chars). Generate with:
#   openssl rand -hex 32
# Rotating this invalidates all active sessions.
SESSION_SECRET=
